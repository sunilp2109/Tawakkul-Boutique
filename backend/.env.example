# ─── Meta WhatsApp Cloud API ─────────────────────────────────────────────────
# Get these from https://developers.facebook.com > Your App > WhatsApp > API Setup

# The Phone Number ID shown in the WhatsApp API Setup dashboard
META_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID

# Permanent System User Access Token (or temporary test token)
META_WHATSAPP_TOKEN=YOUR_ACCESS_TOKEN

# API version — leave as default unless Meta instructs you to upgrade
META_API_VERSION=v21.0

# Set to "false" to silently skip all WhatsApp messages (useful for local dev)
WHATSAPP_NOTIFICATIONS=true

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/tawakkul

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key
